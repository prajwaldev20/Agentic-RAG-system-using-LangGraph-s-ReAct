# Environment Configuration for HW: Agentic RAG with ReAct
# Copy this file to .env and fill in all four keys.
#   cp env.template .env

# OpenAI API Key (required) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Tavily API Key (required) — https://tavily.com (free tier: 1000/mo)
# Used by the WebSearchTool for general web queries.
TAVILY_API_KEY=

# SerpAPI Key (required) — https://serpapi.com/users/sign_up?plan=free (free tier: 100/mo)
# Used by the directors tool for URL-precise LinkedIn lookups with the site:linkedin.com/in/ filter.
SERPAPI_API_KEY=

# LangSmith / LangChain tracing (REQUIRED for this assignment)
# Get a key at https://smith.langchain.com/settings
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=LLM_HW
